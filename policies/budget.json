{
  "scope": "org",
  "currencies": ["model_calls", "searches", "usd"],
  "vars": { "price": { "search": 0.005 } },
  "meters": [
    { "match": "decision.rule == 'model-api'", "spend": { "model_calls": "1" } },
    { "match": "decision.rule == 'web-search'", "spend": { "searches": "1", "usd": "vars.price.search" } }
  ]
}
